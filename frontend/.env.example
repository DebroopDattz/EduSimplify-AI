# ──────────────────────────────────────────────
#  EduSimplify AI — Environment Variables
# ──────────────────────────────────────────────
# Copy this file to .env.local and fill in values.

# Backend API
NEXT_PUBLIC_API_URL=http://localhost:8000

# IBM App ID OAuth (OIDC)
NEXT_PUBLIC_APP_ID_CLIENT_ID=your-app-id-client-id
NEXT_PUBLIC_APP_ID_DISCOVERY_ENDPOINT=https://<region>.appid.cloud.ibm.com/oauth/v4/<tenant-id>/.well-known/openid-configuration
NEXT_PUBLIC_APP_ID_TENANT_ID=your-tenant-id
NEXT_PUBLIC_APP_ID_REGION=us-south
NEXT_PUBLIC_APP_ID_REDIRECT_URI=http://localhost:3000/auth/callback

# IBM App ID Server-side (NOT exposed to browser)
APP_ID_CLIENT_SECRET=your-app-id-client-secret
APP_ID_MGMT_URL=https://<region>.appid.cloud.ibm.com/management/v4/<tenant-id>

# Google OAuth (via App ID or direct)
NEXT_PUBLIC_GOOGLE_CLIENT_ID=your-google-oauth-client-id

# NextAuth / Session secret
NEXTAUTH_SECRET=your-nextauth-secret-min-32-chars
NEXTAUTH_URL=http://localhost:3000

# IBM Cloud Object Storage (for PDF uploads)
NEXT_PUBLIC_COS_ENDPOINT=https://s3.<region>.cloud-object-storage.appdomain.cloud
COS_API_KEY=your-cos-api-key
COS_INSTANCE_CRN=crn:v1:bluemix:public:cloud-object-storage:global:a/...
COS_BUCKET_NAME=edusimplify-uploads

# IBM watsonx.ai
WATSONX_API_KEY=your-watsonx-api-key
WATSONX_PROJECT_ID=your-watsonx-project-id
WATSONX_URL=https://us-south.ml.cloud.ibm.com

# Feature flags
NEXT_PUBLIC_ENABLE_GUEST_MODE=true
NEXT_PUBLIC_ENABLE_TRANSLATION=true
NEXT_PUBLIC_ENABLE_FLASHCARDS=true
NEXT_PUBLIC_MAX_FILE_SIZE_MB=25

# Analytics (optional)
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://app.posthog.com
